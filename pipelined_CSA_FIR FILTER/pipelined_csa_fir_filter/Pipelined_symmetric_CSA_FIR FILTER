`timescale 1ns / 1ps

module SYMMETRIC_FIR(
     input clk,
     input rst,
     input signed [7:0] x_in,
     output reg signed [19:0]y_out
    );
    
    parameter signed [7:0] h0=1,h1=2,h2=3,h3=4;  //symmetric co-efficients
    reg signed [7:0] d0,d1,d2,d3,d4,d5,d6,d7; //delay register
     
    reg signed [8:0] s0_reg,s1_reg,s2_reg,s3_reg;//stage1 pair addition register
    reg signed [16:0] p0_reg,p1_reg,p2_reg,p3_reg; //stage2 multiplier register
           
    
    wire signed [16:0] sum_wire;   //for CSA instantiation
    wire signed [16:0] carry_wire;

    reg signed [16:0] sum_reg;
    reg signed [16:0] carry_reg;
    //wire signed [18:0] csa_result;

    //assign csa_result=sum_reg+(carry_reg<<<1);
          
    CSA dut2(p0_reg,p1_reg,p2_reg,sum_wire,carry_wire);
    //delay line
    always@(posedge clk or posedge rst)
    begin
      if(rst)
      begin
      {d0,d1,d2,d3,d4,d5,d6,d7}<=0;
      end
      else
      begin
       d7<=d6;
       d6<=d5;
       d5<=d4;
       d4<=d3;
       d3<=d2;
       d2<=d1;
       d1<=d0;
       d0<=x_in;
      end
    end
    //stage 1
    always@(posedge clk or posedge rst)
    begin
      if(rst)
      begin
        {s0_reg,s1_reg,s2_reg,s3_reg}<=0;
      end
      else
      begin
       s0_reg<=d0+d7;
       s1_reg<=d1+d6;
       s2_reg<=d2+d5;
       s3_reg<=d3+d4;
      end
    end
    
    //stage2
     always@(posedge clk or posedge rst)
    begin
      if(rst)
      begin
        {p0_reg,p1_reg,p2_reg,p3_reg}<=0;
      end
      else
      begin
       p0_reg<=s0_reg*h0;
       p1_reg<=s1_reg*h1;
       p2_reg<=s2_reg*h2;
       p3_reg<=s3_reg*h3;
      end
    end
    
    //stage3
     always@(posedge clk or posedge rst)
    begin
      if(rst)
      begin
        {sum_reg,carry_reg}<=0;
      end
      else
      begin
       sum_reg<=sum_wire;
       carry_reg<=carry_wire;
      end
    end
       
    //stage4
    //FIR calculation
    always@(posedge clk or posedge rst)
    begin
     if(rst)
      y_out<=0;
     else
      y_out<=sum_reg+(carry_reg>>>1)+p3_reg;
    end 
endmodule
